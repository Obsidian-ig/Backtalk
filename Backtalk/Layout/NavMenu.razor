    <div class="navmenu-brand-container">
        <img src="@Assets["logo.png"]" alt="logo" class="navmenu-logo-image" />
    </div>
    <div class="navmenu-navlinks-container">
        <a class="navmenu-navlink navmenu-navlink-active" href="projects">Home</a>
        <a class="navmenu-navlink" href="projects">Projects</a>
        <a class="navmenu-navlink" href="projects">About</a>
    </div>
    
