@using Backtalk.Components
@inherits LayoutComponentBase
<div class="page oswald">
    <CascadingValue Value="@theme">
        <div class="navmenu-container">
            <NavMenu />
        </div>

        <main>
            <article class="content px-4">
                <NotificationManager />
                <Background />
                @Body
            </article>
        </main>
    </CascadingValue>
</div>

@code {
    public string theme = "light";
}